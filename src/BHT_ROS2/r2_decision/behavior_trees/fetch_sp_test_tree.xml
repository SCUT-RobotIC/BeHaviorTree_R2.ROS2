<root>
    <BehaviorTree ID="MainTree">
        <Sequence>
            <RetryUntilSuccessful num_attempts="-1">
                <R2Initial, timeout = 10, Position_To_FetchSp = {PTFSP}/>
                <MoveToPosition, target_position = {PTFSP}/>
                <TfListen, Target_Position = {PTFSP}, timeout = 10/>
                <FetchSp, Align_Position = {Align_Position}/>
            </RetryUntilSuccessful>
        </Sequence>
    </BehaviorTree>
</root>
